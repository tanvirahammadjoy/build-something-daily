# ─── Database ───────────────────────────────────────────────────────────────
# Local Docker  →  update host/port if running postgres elsewhere
DATABASE_URL="postgresql://streamforge:streamforge_secret@localhost:5432/streamforge?schema=public"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET="your_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# ─── OAuth providers ─────────────────────────────────────────────────────────
# Google: https://console.cloud.google.com  (OAuth 2.0 client → Web application)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub: https://github.com/settings/developers  (OAuth App)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── UploadThing ─────────────────────────────────────────────────────────────
# Sign up at https://uploadthing.com  →  Create app  →  copy keys
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=""
